# AGJCONFIN — variabili d'ambiente
# Copia questo file in ".env" e inserisci i tuoi valori.

# Chiave API Resend (https://resend.com) — necessaria per l'invio email del form
# Contatti e per le iscrizioni alla newsletter.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Indirizzo che riceve le richieste di contatto e le iscrizioni newsletter.
CONTACT_TO=nome@tuodominio.it

# Mittente verificato su Resend. In modalità test usa "AGJCONFIN <onboarding@resend.dev>".
CONTACT_FROM=AGJCONFIN <noreply@agjconfin.it>
